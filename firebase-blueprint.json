{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "createdAt": { "type": "number", "description": "Timestamp when the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "Plan": {
      "title": "Action Plan",
      "description": "Stores a generated action plan.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the plan." },
        "userId": { "type": "string", "description": "The ID of the user who owns the plan." },
        "requirement": { "type": "string", "description": "The user's initial requirement." },
        "startDate": { "type": "string", "description": "The start date of the plan." },
        "endDate": { "type": "string", "description": "The end date of the plan." },
        "hoursPerWeek": { "type": "number", "description": "The available hours per week." },
        "content": { "type": "string", "description": "The Markdown content of the plan." },
        "createdAt": { "type": "number", "description": "Timestamp when the plan was created." }
      },
      "required": ["id", "userId", "requirement", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Generated action plans."
    }
  }
}
